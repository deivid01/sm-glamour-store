{
    "version": 2,
    "builds": [
        {
            "src": "backend/sm_glamour_backend/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "runtime": "python3.9"
            }
        },
        {
            "src": "backend/build_files.sh",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "staticfiles"
            }
        }
    ],
    "routes": [
        {
            "src": "/(?:api|admin|media|static)/(.*)",
            "dest": "backend/sm_glamour_backend/wsgi.py"
        }
    ]
}