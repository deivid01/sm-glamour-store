{
    "outputDirectory": "dist",
    "crons": [
        {
            "path": "/api/integrations/olist/sync",
            "schedule": "0 * * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
