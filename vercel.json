{
    "version": 2,
    "builds": [
        {
            "src": "backend/sm_glamour_backend/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb"
            }
        },
        {
            "src": "backend/build_files.sh",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "backend/staticfiles"
            }
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/backend/staticfiles/$1"
        },
        {
            "src": "/(api|admin)(.*)",
            "dest": "backend/sm_glamour_backend/wsgi.py"
        }
    ]
}